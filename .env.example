# TraceFix environment - copy to `.env` and fill in the keys you need.
# `.env` is gitignored and is auto-loaded from the repo root at runtime.

# LLM provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional: override the verification toolchain location if doctor cannot find it.
# TLA_VERIFY_JAVA=/path/to/java17/bin/java
# TLA_VERIFY_JAR=/path/to/tla2tools.jar

# TeLLMe CityOS capability discovery. Test mode uses a local privacy-safe fixture.
CITYOS_DISCOVERY_MODE=test
CITYOS_DISCOVERY_PROVIDER=mock
CITYOS_DISCOVERY_FIXTURE_PATH=
CITYOS_DISCOVERY_SERVICE_URL=
CITYOS_DISCOVERY_BEARER_TOKEN=
CITYOS_DISCOVERY_TIMEOUT_SECONDS=5
CITYOS_DISCOVERY_RETRY_COUNT=1
CITYOS_DISCOVERY_SCHEMA_VERSION=1.1
CITYOS_DISCOVERY_MAX_RESPONSE_BYTES=250000
CITYOS_DISCOVERY_MAX_CAPABILITY_COUNT=256

# Capability service / bridge. Production requires explicit tokens and approved metadata.
CAPABILITY_SERVICE_MODE=test
CAPABILITY_SERVICE_APPROVED_CAPABILITIES_PATH=
CAPABILITY_SERVICE_DISCOVERY_TOKEN=
CAPABILITY_SERVICE_PUBLISHER_TOKEN=
CAPABILITY_BRIDGE_SNAPSHOT_PATH=
CAPABILITY_BRIDGE_SERVICE_URL=http://127.0.0.1:8080
CAPABILITY_BRIDGE_PUBLISHER_TOKEN=
CAPABILITY_BRIDGE_DRY_RUN=true
